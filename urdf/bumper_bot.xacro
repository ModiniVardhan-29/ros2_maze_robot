<?xml version="1.0"?>

<robot name="bumper_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- PARAMETERS -->

  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_width" value="0.03"/>

  <!-- BASE LINK -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.30 0.25 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="0.30 0.25 0.05"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="4"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>


  <!-- LEFT WHEEL -->

  <link name="left_wheel">

    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>


  <!-- RIGHT WHEEL -->

  <link name="right_wheel">

    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>


  <!-- WHEEL JOINTS -->

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.13 -${wheel_radius}"/>
    <axis xyz="0 1 0"/>
  </joint>


  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.13 -${wheel_radius}"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- LIDAR -->

  <link name="lidar_link">

    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
    </visual>

  </link>


  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.12"/>
  </joint>


  <!-- LIDAR SENSOR -->

  <gazebo reference="lidar_link">

    <sensor type="ray" name="lidar">

      <update_rate>30</update_rate>
      <visualize>true</visualize>

      <ray>

        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.12</min>
          <max>6.0</max>
        </range>

      </ray>

      <plugin name="gazebo_ros_ray_sensor"
              filename="libgazebo_ros_ray_sensor.so">

        <ros>
          <remapping>~/out:=/scan</remapping>
        </ros>

        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>

      </plugin>

    </sensor>

  </gazebo>


  <!-- DIFF DRIVE -->

  <gazebo>

    <plugin name="diff_drive_controller"
            filename="libgazebo_ros_diff_drive.so">

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.26</wheel_separation>
      <wheel_diameter>0.12</wheel_diameter>

      <command_topic>cmd_vel</command_topic>

      <odometry_topic>odom</odometry_topic>

      <robot_base_frame>base_link</robot_base_frame>

    </plugin>

  </gazebo>

</robot>

